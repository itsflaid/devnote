generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────────────
// USER
// ───────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  likes    Like[]
  snippets    Snippet[]
  collections Collection[]
  ownedWorkspaces        Workspace[]          @relation("WorkspaceOwner")
  workspaceMembers      WorkspaceMember[]
  workspaceSnippetsAdded WorkspaceSnippet[]   @relation("WorkspaceSnippetAdder")

  @@map("users")
}

// ───────────────────────────────
// SNIPPET
// ───────────────────────────────
model Snippet {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  code        String
  language    String
  isPublic    Boolean  @default(false)
  shareId     String?  @unique
  copyCount   Int      @default(0)
  isFavorite  Boolean  @default(false)

  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes    Like[]
  tags        SnippetTag[]
  collections SnippetCollection[]

  workspaces WorkspaceSnippet[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("snippets")
}

// ───────────────────────────────
// COLLECTION
// ───────────────────────────────
model Collection {
  id        Int      @id @default(autoincrement())
  name      String

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  snippets  SnippetCollection[]

  createdAt DateTime @default(now())

  @@map("collections")
}

model SnippetCollection {
  snippetId    Int
  collectionId Int

  snippet    Snippet    @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([snippetId, collectionId])
  @@map("snippet_collections")
}

// ───────────────────────────────
// TAG
// ───────────────────────────────
model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  snippets SnippetTag[]

  @@map("tags")
}

// ───────────────────────────────
// SNIPPET_TAG (pivot)
// ───────────────────────────────
model SnippetTag {
  snippetId Int
  tagId     Int

  snippet Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([snippetId, tagId])
  @@map("snippet_tags")
}


model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  snippetId Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])
  @@map("likes")
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

model Workspace {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  inviteCode  String   @unique

  ownerId     Int
  owner       User     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members     WorkspaceMember[]
  snippets    WorkspaceSnippet[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workspaces")
}

model WorkspaceMember {
  id          Int           @id @default(autoincrement())
  workspaceId Int
  userId      Int
  role        WorkspaceRole @default(VIEWER)

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceSnippet {
  workspaceId Int
  snippetId   Int
  addedById   Int

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snippet     Snippet   @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  addedBy     User      @relation("WorkspaceSnippetAdder", fields: [addedById], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@id([workspaceId, snippetId])
  @@map("workspace_snippets")
}